    "@unhead/vue": "^1.11.18",
    "@vueuse/core": "^12.0.0",
    "axios": "^1.7.7",
    "bootstrap": "^5.3.3",
    "core-js": "^3.36.1",
    "firebase": "^11.0.2",
    "pinia": "^2.2.6",
    "regenerator-runtime": "^0.14.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
